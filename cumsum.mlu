#include <torch/extension.h>
#include <iostream>

torch::Tensor bang_func(torch::Tensor x, int dim) {
    std::cout << "[DEBUG] x dtype: " << x.scalar_type() << std::endl;
    std::cout << "[DEBUG] x dim: " << x.dim() << std::endl;
    std::cout << "[DEBUG] input dim arg: " << dim << std::endl;

    for (int i = 0; i < x.dim(); ++i) {
        std::cout << "[DEBUG] size[" << i << "]: " << x.size(i) << std::endl;
    }

    return torch::empty_like(x);
}
